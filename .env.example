# Qdrant Cloud Configuration
QDRANT_URL="https://your-qdrant-instance.cloud.qdrant.io:6333"
QDRANT_API_KEY="your-qdrant-api-key"

# AWS Credentials (leave empty when using EC2 Instance Profile)
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_SESSION_TOKEN=""

# AWS Region (required for Opus 4.6 with us.* prefix)
AWS_REGION=us-east-1

# Local dev: SSH tunnel to Qdrant Cloud (set to true when using tunnel)
# EC2: leave false or unset — connects directly to Qdrant Cloud
QDRANT_TUNNEL=false
